# --- DATABASE_URL ---
#
# Ошибка Prisma P1000 («credentials for grandastra are not valid») значит: на localhost:5432
# другой PostgreSQL (не из docker-compose) или роль grandastra ещё не создана.
#
# Вариант 1 — только контейнер из корня репозитория (порт 5432 не должен занять другой Postgres):
#   npm run docker:postgres
#   затем: npm run db:migrate -w @grandastra/api && npm run db:seed -w @grandastra/api
#
# Вариант 2 — свой установленный PostgreSQL: создать пользователя и БД
#   psql -h localhost -U postgres -d postgres -f scripts/postgres-dev-setup.sql
#
# Вариант 3 — без пользователя grandastra: URL с вашим суперпользователем и существующей БД, например
#   DATABASE_URL="postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5432/grandastra"
#   (БД grandastra создайте: CREATE DATABASE grandastra;)
#
DATABASE_URL="postgresql://grandastra:grandastra@localhost:5432/grandastra"

JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=3000

# --- Render.com ---
#
# Web Service (API) в том же регионе, что и Render Postgres → в панели БД скопируйте
# «Internal Database URL» в DATABASE_URL (приватная сеть Render).
#
# Миграции с ноутбука / вне Render → «External Database URL»; часто нужен SSL:
#   DATABASE_URL="postgresql://USER:PASS@HOST.REGION-postgres.render.com/DB?sslmode=require"
#
# JWT_SECRET — длинная случайная строка; PORT на Render не задавайте (задаёт платформа).
