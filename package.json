{
  "name": "grandastra-crm",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @grandastra/api\" \"npm run dev -w @grandastra/web\"",
    "build": "npm run build -w @grandastra/api && npm run build -w @grandastra/web",
    "db:generate": "npm exec --workspace=@grandastra/api -- prisma generate",
    "db:migrate": "npm exec --workspace=@grandastra/api -- prisma migrate dev",
    "db:migrate:deploy": "npm exec --workspace=@grandastra/api -- prisma migrate deploy",
    "db:seed": "npm exec --workspace=@grandastra/api -- prisma db seed",
    "docker:postgres": "docker compose up -d postgres",
    "start:api": "node apps/api/dist/src/main.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
